# Environment variables (copy to .env — never commit .env)

# Application
# APP_ENV=development
# APP_PORT=3000

# Database
# DATABASE_URL=postgres://attendance_app:secret@localhost:5432/openpresence?sslmode=disable

# Auth / secrets (generate per environment)
# JWT_SECRET=
# ENCRYPTION_KEY=

# Biometric service (Rust)
# BIOMETRIC_USE_STUB=true          # set false when ONNX models are on disk
# BIOMETRIC_GRPC_ADDR=0.0.0.0:9090
# BIOMETRIC_HTTP_ADDR=0.0.0.0:9091
# ONNX_MODELS_PATH=./models        # run ./scripts/download-models.sh first
