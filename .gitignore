# Local AI workspace (tasks, overrides, context — not versioned)
.local/

# Cursor rules (local per machine — restore via scripts/setup-local-ai.sh)
.cursor/

# Environment and secrets
.env
.env.*
!.env.example

# OS and IDE (non-Cursor)
.DS_Store
.idea/
*.swp

# Python tooling (harness scripts)
__pycache__/
.venv/
venv/

# Node / build artifacts (add stack-specific entries as the project grows)
node_modules/
dist/
*.tsbuildinfo
build/
coverage/

# Gradle / Kotlin
.gradle/
.kotlin/
**/build/
!**/src/**/build/

# ONNX model weights (download separately — see docs/BIOMETRICS.md)
models/*
!models/MANIFEST.json
!models/.gitkeep

# Rust build artifacts
**/target/
